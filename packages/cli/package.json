{
  "name": "paranoia-cli",
  "version": "1.0.0",
  "description": "Post-quantum hybrid encryption CLI — seal and open files with ML-KEM-1024 + P-521 + AES-256-GCM, generate entropy, and manage keypairs.",
  "type": "module",
  "bin": {
    "paranoia": "./dist/index.cjs"
  },
  "scripts": {
    "build":     "tsup",
    "dev":       "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "post-quantum",
    "encryption",
    "cli",
    "ml-kem",
    "p-521",
    "argon2id",
    "file-encryption",
    "paranoia-ts"
  ],
  "author": {
    "name": "Matéo Florian Callec",
    "email": "mateo@callec.net"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateocallec/paranoia.ts.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/mateocallec/paranoia.ts#cli",
  "bugs": {
    "url": "https://github.com/mateocallec/paranoia.ts/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@noble/hashes": "^1.5.0",
    "commander": "^12.1.0",
    "paranoia-ts": "*",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
